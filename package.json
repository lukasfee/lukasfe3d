{
  "name": "nexa-erp-industrial",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukasfee/lukasfe3d.git"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "clean:release": "node -e \"require('fs').rmSync('release', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "test": "tsc --noEmit",
    "electron": "cross-env VITE_APP_ENV=producao electron .",
    "electron:teste": "cross-env VITE_APP_ENV=teste electron .",
    "dist": "cross-env VITE_APP_ENV=producao npm run build && electron-builder",
    "dist:teste": "cross-env VITE_APP_ENV=teste npm run build && electron-builder --config electron-builder-teste.json",
    "electron:publish": "cross-env VITE_APP_ENV=producao npm run clean:release && npm run build && electron-builder --publish always"
  },
  "build": {
    "electronVersion": "36.9.5",
    "appId": "com.nexaerp.industrial",
    "productName": "Nexa ERP Industrial",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "lukasfee",
        "repo": "lukasfe3d"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!release/**",
      "!backups/**",
      "!*.zip",
      "!*.log",
      "!*.db",
      "!*.sqlite",
      "!*.sqlite3"
    ],
    "compression": "normal",
    "asar": true,
    "asarUnpack": [],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@zxing/library": "^0.22.0",
    "better-sqlite3": "^11.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "html2canvas-pro": "^2.0.4",
    "html5-qrcode": "^2.3.8",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "36.9.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
